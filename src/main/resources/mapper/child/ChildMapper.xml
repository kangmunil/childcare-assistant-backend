<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.childcare.domain.child.mapper.ChildMapper">

    <resultMap id="childResultMap" type="com.childcare.domain.child.entity.Child">
        <id property="chSeq" column="ch_seq"/>
        <result property="name" column="name"/>
        <result property="birthDay" column="birth_day"/>
        <result property="birthTime" column="birth_time"/>
        <result property="gender" column="gender"/>
        <result property="memo" column="memo"/>
        <result property="height" column="height"/>
        <result property="weight" column="weight"/>
        <result property="regId" column="reg_id" typeHandler="com.childcare.global.config.UuidTypeHandler"/>
        <result property="regDate" column="reg_date"/>
        <result property="deleteYn" column="delete_yn"/>
        <result property="deleteId" column="delete_id" typeHandler="com.childcare.global.config.UuidTypeHandler"/>
        <result property="deleteDate" column="delete_date"/>
    </resultMap>

    <select id="findActiveChildrenByMemberId" resultMap="childResultMap">
        <![CDATA[
        SELECT c.*
        FROM member m
        JOIN parent p ON m.id = p.mb_id AND p.auth_read = '1'
        JOIN child c ON c.ch_seq = p.ch_seq AND (c.delete_yn IS NULL OR c.delete_yn != 'Y')
        WHERE m.id = #{memberId}::uuid
        ]]>
    </select>

    <select id="findActiveChildById" resultMap="childResultMap">
        <![CDATA[
        SELECT *
        FROM child
        WHERE ch_seq = #{childId}
          AND (delete_yn IS NULL OR delete_yn != 'Y')
        ]]>
    </select>

    <resultMap id="growthHistoryResultMap" type="com.childcare.domain.child.dto.GrowthHistoryDto">
        <result property="childId" column="ch_seq"/>
        <result property="month" column="month"/>
        <result property="height" column="height"/>
        <result property="weight" column="weight"/>
    </resultMap>

    <select id="findGrowthHistory" resultMap="growthHistoryResultMap">
        <![CDATA[
        SELECT ch_seq, month, height, weight
        FROM (
            SELECT
                c.ch_seq,
                TO_CHAR(DATE_TRUNC('month', h.reg_date), 'YYYY-MM') AS month,
                h.height,
                h.weight,
                ROW_NUMBER() OVER (
                    PARTITION BY h.ch_seq, DATE_TRUNC('month', h.reg_date)
                    ORDER BY h.reg_date DESC
                ) rn
            FROM child c
            JOIN child_grow_history h ON c.ch_seq = h.ch_seq
                AND (h.delete_yn IS NULL OR h.delete_yn != 'Y')
            WHERE (c.delete_yn IS NULL OR c.delete_yn != 'Y')
              AND c.ch_seq = #{childId}
              AND h.reg_date >= DATE_TRUNC('month', NOW() - INTERVAL '4 months')
        ) sub
        WHERE rn = 1
        ORDER BY month
        ]]>
    </select>

</mapper>
