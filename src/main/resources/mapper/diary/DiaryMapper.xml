<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.childcare.domain.diary.mapper.DiaryMapper">

    <resultMap id="childDiaryResultMap" type="com.childcare.domain.diary.entity.ChildDiary">
        <id property="diSeq" column="di_seq"/>
        <result property="chSeq" column="ch_seq"/>
        <result property="ccDiSeq" column="cc_di_seq"/>
        <result property="diDate" column="di_date"/>
        <result property="diTime" column="di_time"/>
        <result property="amount" column="amount"/>
        <result property="memo" column="memo"/>
        <result property="regAiYn" column="reg_ai_yn"/>
        <result property="regUserSeq" column="reg_user_seq"/>
        <result property="regDate" column="reg_date"/>
        <result property="deleteYn" column="delete_yn"/>
        <result property="deleteUserSeq" column="delete_user_seq"/>
        <result property="deleteDate" column="delete_date"/>
    </resultMap>

    <resultMap id="ccDiaryItemResultMap" type="com.childcare.domain.diary.entity.CcDiaryItem">
        <id property="ccDiSeq" column="cc_di_seq"/>
        <result property="ccDiDiv" column="cc_di_div"/>
        <result property="ccDiCode" column="cc_di_code"/>
        <result property="ccDiName" column="cc_di_name"/>
        <result property="ccDiUnit" column="cc_di_unit"/>
        <result property="regUserSeq" column="reg_user_seq"/>
        <result property="regDate" column="reg_date"/>
        <result property="deleteYn" column="delete_yn"/>
        <result property="deleteUserSeq" column="delete_user_seq"/>
        <result property="deleteDate" column="delete_date"/>
    </resultMap>

    <sql id="FromDiary">
        <![CDATA[
        FROM child c
        JOIN child_diary d on c.ch_seq = d.ch_seq AND (d.delete_yn IS NULL OR d.delete_yn != 'Y')
        WHERE (c.delete_yn IS NULL OR c.delete_yn != 'Y')
          AND c.ch_seq = ${childId}
        ]]>
    </sql>

    <sql id="orderByDiary">
        <![CDATA[
        ORDER BY d.di_date DESC, d.di_time DESC
        ]]>
    </sql>

    <!-- ChildDiary 관련 쿼리 -->
    <select id="findDiariesByChildId" resultMap="childDiaryResultMap">
        SELECT d.*
        <include refid="FromDiary">
            <property name="childId" value="#{childId}"/>
        </include>
        <include refid="orderByDiary"></include>
    </select>

    <select id="findDiariesByChildIdAndDate" resultMap="childDiaryResultMap">
        SELECT d.*
        <include refid="FromDiary">
            <property name="childId" value="#{childId}"/>
        </include>
        AND d.di_date = #{diDate}
        <include refid="orderByDiary"></include>
    </select>

    <select id="findActiveDiaryById" resultMap="childDiaryResultMap">
        SELECT d.*
        <include refid="FromDiary">
            <property name="childId" value="#{childId}"/>
        </include>
        AND d.di_seq = #{diSeq}
        <include refid="orderByDiary"></include>
    </select>

    <!-- 일지 요약 (항목별 합계) -->
    <resultMap id="itemSummaryResultMap" type="com.childcare.domain.diary.dto.DiarySummaryDto$ItemSummary">
        <result property="itemId" column="item_id"/>
        <result property="itemDivision" column="item_division"/>
        <result property="itemCode" column="item_code"/>
        <result property="itemName" column="item_name"/>
        <result property="unit" column="unit"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="count" column="count"/>
    </resultMap>

    <sql id="FromDiaryJoinItem">
        <![CDATA[
        FROM child c
        JOIN child_diary d on c.ch_seq = d.ch_seq AND (d.delete_yn IS NULL OR d.delete_yn != 'Y')
        JOIN cc_diary_item i ON d.cc_di_seq = i.cc_di_seq
        WHERE (c.delete_yn IS NULL OR c.delete_yn != 'Y')
          AND c.ch_seq = ${childId}
        ]]>
    </sql>

    <select id="findDailySummaryByChildId" resultMap="itemSummaryResultMap">
        SELECT
            i.cc_di_seq AS item_id,
            i.cc_di_div AS item_division,
            i.cc_di_code AS item_code,
            i.cc_di_name AS item_name,
            i.cc_di_unit AS unit,
            SUM(CAST(COALESCE(NULLIF(d.amount, ''), '0') AS DECIMAL)) AS total_amount,
            COUNT(*) AS count
        <include refid="FromDiaryJoinItem">
            <property name="childId" value="#{childId}"/>
        </include>
          AND d.di_date = #{diDate}
        GROUP BY i.cc_di_seq, i.cc_di_div, i.cc_di_code, i.cc_di_name, i.cc_di_unit
        ORDER BY i.cc_di_seq
    </select>

    <select id="findDailySummaryByDivision" resultMap="itemSummaryResultMap">
        SELECT
            i.cc_di_seq AS item_id,
            i.cc_di_div AS item_division,
            i.cc_di_code AS item_code,
            i.cc_di_name AS item_name,
            i.cc_di_unit AS unit,
            COALESCE(SUM(CAST(COALESCE(NULLIF(d.amount, ''), '0') AS DECIMAL)), 0) AS total_amount,
            COALESCE(COUNT(d.di_seq), 0) AS count
        FROM cc_diary_item i
        LEFT JOIN (
                SELECT d.*
                <include refid="FromDiary">
                    <property name="childId" value="#{childId}"/>
                </include>
                  AND d.di_date = #{diDate}
            ) d ON i.cc_di_seq = d.cc_di_seq
        WHERE i.cc_di_div = #{division}
          AND (i.delete_yn IS NULL OR i.delete_yn != 'Y')
        GROUP BY i.cc_di_seq, i.cc_di_div, i.cc_di_code, i.cc_di_name, i.cc_di_unit
        ORDER BY i.cc_di_seq
    </select>

    <sql id="FromItem">
        <![CDATA[
        FROM cc_diary_item
        WHERE delete_yn IS NULL OR delete_yn != 'Y'
        ]]>
    </sql>

    <!-- CcDiaryItem 관련 쿼리 -->
    <select id="findAllActiveItems" resultMap="ccDiaryItemResultMap">
        SELECT *
        <include refid="FromItem"></include>
        ORDER BY cc_di_seq
    </select>

    <select id="findActiveItemsByDivision" resultMap="ccDiaryItemResultMap">
        SELECT *
        <include refid="FromItem"></include>
          AND cc_di_div = #{division}
        ORDER BY cc_di_seq
    </select>

</mapper>
